.DS_Store

# Build artifacts
/dist/

# Local live registries are not versioned; use registries.example/ as the source of truth.
/registries/

# Private owner data stays local; use owner.example/ as the template source.
/owner/

# Local memory data stays local.
/memory/

# Chat history and attachments are runtime data. Keep example chats only.
/chats/**
!/chats/
!/chats/*.example.jsonl
!/chats/*.example/
!/chats/*.example/**

# Local runtime state under root/ is ignored by default.
# Keep only checked-in .example templates.
/root/**
!/root/
!/root/*.example
!/root/*.example/
!/root/*.example/**

# Demo-only assets stay local.
/agents/*.demo/
/agents/zenmi/agent.yml
/agents/zenmi/AGENTS.md
/agents/*/skills/
/schedules/**
!/schedules/
!/schedules/README.md
!/schedules/*.example.yml
!/schedules/*.example.yaml
/teams/*.demo.yml
/teams/*.demo.yaml
/skills-market/*.demo/
